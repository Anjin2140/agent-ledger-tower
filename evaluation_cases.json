  "policy": [
    {"id": "pg-01-allow-write", "tool": "write_note", "args": {"name": "safe.txt", "text": "hello"}, "expect": {"decision": "ALLOW", "rule": "allow_write_note"}},
    {"id": "pg-02-allow-digest", "tool": "sha256_note", "args": {"name": "safe.txt"}, "expect": {"decision": "ALLOW", "rule": "allow_sha256_note"}},
    {"id": "pg-03-allow-list", "tool": "list_notes", "args": {}, "expect": {"decision": "ALLOW", "rule": "allow_list_notes"}},
    {"id": "pg-04-unknown-default-deny", "tool": "delete_everything", "args": {}, "expect": {"decision": "DENY", "rule": "default_deny"}},
