    {"id": "pg-08-insecure-tls", "tool": "http_get", "args": {"url": "https://example.test", "verify": false}, "expect": {"decision": "DENY", "rule": "no_insecure_tls"}},
    {"id": "pg-09-insecure-flag", "tool": "write_note", "args": {"name": "safe.txt", "text": "run --insecure"}, "expect": {"decision": "DENY", "rule": "no_insecure_tls"}},
    {"id": "pg-10-private-key", "tool": "write_note", "args": {"name": "safe.txt", "text": "BEGIN PRIVATE KEY"}, "expect": {"decision": "DENY", "rule": "no_secret_exfil"}},
    {"id": "pg-11-seed-phrase", "tool": "write_note", "args": {"name": "safe.txt", "text": "seed phrase here"}, "expect": {"decision": "DENY", "rule": "no_secret_exfil"}},
    {"id": "pg-12-deny-precedes-allow", "tool": "write_note", "args": {"name": "../safe.txt", "text": "hello"}, "expect": {"decision": "DENY", "rule": "workspace_only"}}
