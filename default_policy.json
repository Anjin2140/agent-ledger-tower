{
  "version": 2,
  "default": "deny",
  "rules": [
    {"id": "no_insecure_tls", "effect": "deny",
     "when": {"arg_matches": "(?i)verify\\W{0,3}false|cert_none|check_hostname\\W{0,3}false|--insecure|disable_warnings"},
     "reason": "disabling TLS verification is forbidden"},
    {"id": "workspace_only", "effect": "deny",
     "when": {"arg_matches": "(^\\.\\.)|(\\.\\.[\\\\/])|(^[A-Za-z]:[\\\\/])|(^/)"},
     "reason": "path escapes the agent workspace"},
    {"id": "no_secret_exfil", "effect": "deny",
     "when": {"arg_matches": "(?i)private.?key|mnemonic|seed.?phrase|begin (ec |rsa |openssh )?private key"},
     "reason": "action references secret material"},
    {"id": "allow_write_note", "effect": "allow",
     "when": {"tool": "write_note"},
     "reason": "registered workspace write"},
    {"id": "allow_sha256_note", "effect": "allow",
     "when": {"tool": "sha256_note"},
     "reason": "registered workspace digest"},
    {"id": "allow_list_notes", "effect": "allow",
     "when": {"tool": "list_notes"},
     "reason": "registered workspace listing"}
  ]
}